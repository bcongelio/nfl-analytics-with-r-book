remotes::install_github("rstudio/bslib")
install.packages("downlit")
library(bslib)
library(downlit)
data <- nflreadr::load_player_stats(2021)
ay.per.attempt <- data %>%
group_by(player_name) %>%
filter(season_type == "REG") %>%
summarize(n.attempts = sum(attempts),
n.airyards = sum(passing_air_yards),
ay.attempt = n.airyards / n.attempts) %>%
filter(n.attempts >= 400)
library(nflreadr)
library(tidyverse)
ay.per.attempt <- data %>%
group_by(player_name) %>%
filter(season_type == "REG") %>%
summarize(n.attempts = sum(attempts),
n.airyards = sum(passing_air_yards),
ay.attempt = n.airyards / n.attempts) %>%
filter(n.attempts >= 400)
View(ay.per.attempt)
ay.per.attempt <- data %>%
group_by(player_name) %>%
filter(season_type == "REG") %>%
summarize(n.attempts = sum(attempts),
n.airyards = sum(passing_air_yards),
ay.attempt = n.airyards / n.attempts) %>%
filter(n.attempts >= 400) %>%
arrange(desc(ay.attempt))
View(data)
ay.five.years <- nflreadr::load_pbp(2017:2021)
View(ay.five.years)
tibble(ay.five.years)
airyards.fiveyears <- ay.five.years %>%
group_by(passer, passer_id) %>%
filter(season_type == "REG" & complete_pass == 1) %>%
summarize(avg.ay = mean(air_yards, na.rm = T))
View(airyards.fiveyears)
